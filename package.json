{
  "name": "queueflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "psql \"$DATABASE_URL\" -f migrations/001_init.sql && psql \"$DATABASE_URL\" -f migrations/002_postgres_support.sql",
    "db:peek": "node scripts/db-peek.cjs",
    "test": "npm run test:all",
    "test:build": "npm run build",
    "test:lint": "npm run lint",
    "test:smoke": "bash ./scripts/test-smoke.sh",
    "test:all": "npm run test:build && npm run test:lint && npm run test:smoke"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.383.0",
    "next": "^15.5.18",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9",
    "autoprefixer": "^10.0.1",
    "eslint": "8.57.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
